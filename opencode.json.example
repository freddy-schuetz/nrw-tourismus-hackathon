{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "n8n-mcp": {
      "type": "local",
      "command": ["npx", "-y", "n8n-mcp"],
      "enabled": true,
      "environment": {
        "N8N_API_URL": "https://DEINE-INSTANZ.app.n8n.cloud",
        "N8N_API_KEY": "DEIN_N8N_API_KEY",
        "MCP_MODE": "stdio",
        "LOG_LEVEL": "error",
        "DISABLE_CONSOLE_OUTPUT": "true"
      }
    }
  }
}
